# Copy to .env at repo root. Not legal advice — obtain professional review for your jurisdiction.

# Primary jurisdiction(s) for securities and tax (ISO country codes, comma-separated)
GTP_JURISDICTIONS=US

# Require paper/sandbox before live per venue: true|false
GTP_PAPER_FIRST=true

# Rollout: paper_only | paper_then_live (live only after explicit flag day per venue)
GTP_ROLLOUT_MODE=paper_then_live

# Kill switch: when true, no orders are sent (checked in risk engine)
GTP_KILL_SWITCH=false

# Max daily loss in base currency (e.g. USD) — enforced in risk layer
GTP_MAX_DAILY_LOSS_BASE=5000

# Base currency for portfolio aggregation
GTP_BASE_CURRENCY=USD

# Interactive Brokers: use TWS or IB Gateway; start with paper account
GTP_IBKR_HOST=127.0.0.1
GTP_IBKR_PORT=7497
GTP_IBKR_CLIENT_ID=1
# Set to 1 to avoid live TWS during development (simulated adapter)
GTP_IBKR_USE_STUB=1

# Crypto (CEX) — never commit real keys
GTP_CRYPTO_EXCHANGE=binance
GTP_CRYPTO_API_KEY=
GTP_CRYPTO_API_SECRET=
GTP_CRYPTO_SANDBOX=1

# Structured logging: json | console
GTP_LOG_FORMAT=json

# SQLite audit database path
GTP_AUDIT_DB_PATH=var/audit.sqlite3
