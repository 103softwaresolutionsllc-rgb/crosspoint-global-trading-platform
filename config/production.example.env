# Production / paper-live template — copy to .env and fill secrets.

GTP_JURISDICTIONS=US
GTP_PAPER_FIRST=true
GTP_ROLLOUT_MODE=paper_then_live
GTP_KILL_SWITCH=false
GTP_MAX_DAILY_LOSS_BASE=5000
GTP_BASE_CURRENCY=USD

# IBKR paper=7497, live=7496 — TWS/Gateway must be running on host
GTP_IBKR_HOST=127.0.0.1
GTP_IBKR_PORT=7497
GTP_IBKR_CLIENT_ID=1
GTP_IBKR_DASHBOARD_CLIENT_ID=2
GTP_IBKR_USE_STUB=0

GTP_WATCHLIST=AAPL,NVDA,MSFT,GOOGL,AMZN
GTP_SIGNAL_TICKER=AAPL
GTP_ASSET_CLASS=equity
GTP_CONTRACT_EXCHANGE=SMART
GTP_CONTRACT_EXPIRY=
GTP_OPTION_STRIKE=
GTP_OPTION_RIGHT=C
GTP_PORTFOLIO_VALUE=100000
GTP_BASE_ORDER_QTY=100
GTP_MAX_DRAWDOWN_PCT=10
GTP_DASHBOARD_AUTH_ENABLED=1
GTP_DASHBOARD_USER=crosspoint
GTP_DASHBOARD_PASSWORD=change-me
GTP_DASHBOARD_SECRET=change-me-secret

# Autopilot: powershell -ExecutionPolicy Bypass -File scripts/autopilot.ps1
GTP_AUTOPILOT_IBKR=1
GTP_AUTOPILOT_INTERVAL_MINUTES=60

FRED_API_KEY=
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

GTP_CRYPTO_SANDBOX=1
GTP_LOG_FORMAT=json
GTP_AUDIT_DB_PATH=var/audit.sqlite3
CELERY_BROKER_URL=redis://localhost:6379/0
